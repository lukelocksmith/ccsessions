#!/bin/bash
# cn — Claude New project
# Użycie: cn nazwa-projektu

CONFIG_FILE="$HOME/.config/ccsessions"

# Wczytaj config
DANGEROUSLY_SKIP_PERMISSIONS="true"
BROWSER="chrome"
MODEL="sonnet"
EFFORT="high"
PROJECTS_DIR="$HOME/Projects"
TMUX_ENABLED="true"

if [ -f "$CONFIG_FILE" ]; then
    while IFS='=' read -r key val; do
        [[ "$key" =~ ^#.*$ || -z "$key" ]] && continue
        key=$(echo "$key" | xargs)
        val=$(echo "$val" | xargs)
        case "$key" in
            DANGEROUSLY_SKIP_PERMISSIONS) DANGEROUSLY_SKIP_PERMISSIONS="$val" ;;
            BROWSER) BROWSER="$val" ;;
            PROJECTS_DIR) PROJECTS_DIR="${val/#\~/$HOME}" ;;
            TMUX) TMUX_ENABLED="$val" ;;
            MODEL) MODEL="$val" ;;
            EFFORT) EFFORT="$val" ;;
        esac
    done < "$CONFIG_FILE"
fi

# Buduj flagi
CLAUDE_FLAGS=""
[ "$DANGEROUSLY_SKIP_PERMISSIONS" = "true" ] && CLAUDE_FLAGS="--dangerously-skip-permissions"
[ "$BROWSER" != "none" ] && [ -n "$BROWSER" ] && CLAUDE_FLAGS="$CLAUDE_FLAGS --$BROWSER"
[ "$MODEL" != "none" ] && [ -n "$MODEL" ] && CLAUDE_FLAGS="$CLAUDE_FLAGS --model $MODEL"
[ "$EFFORT" != "none" ] && [ -n "$EFFORT" ] && CLAUDE_FLAGS="$CLAUDE_FLAGS --effort $EFFORT"

if [ -z "$1" ]; then
    echo "Użycie: cn nazwa-projektu"
    exit 1
fi

PROJECT_PATH="$PROJECTS_DIR/$1"

if [ -d "$PROJECT_PATH" ]; then
    echo "Folder już istnieje: $PROJECT_PATH — wchodzę..."
else
    mkdir -p "$PROJECT_PATH"
    echo "✓ Utworzono: $PROJECT_PATH"
fi

SESSION_NAME="claude-$(basename "$PROJECT_PATH")"

if [ "$TMUX_ENABLED" = "true" ]; then
    if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
        echo "→ Podpinam się do tmux: $SESSION_NAME"
        exec tmux attach -t "$SESSION_NAME"
    else
        echo "→ Nowa sesja tmux: $SESSION_NAME"
        exec tmux new-session -s "$SESSION_NAME" -c "$PROJECT_PATH" claude $CLAUDE_FLAGS
    fi
else
    cd "$PROJECT_PATH"
    exec claude $CLAUDE_FLAGS
fi
